{
  "name": "agda-mode",
  "displayName": "agda-mode",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "license": "MIT",
  "categories": [
    "Programming Languages"
  ],
  "repository": "github:stickyPiston/agda-mode-vscode",
  "main": "./bundle.js",
  "contributes": {
    "configuration": {
      "title": "",
      "type": "object",
      "properties": {
        "agda-mode.agda-path": {
          "type": "string",
          "description": "Path to the agda binary, when left empty, the agda binary on the PATH is used. If you change this setting, you can restart the agda process used by the extension with the restart command (C-c C-x C-r)."
        },
        "agda-mode.extra-args": {
          "type": "string",
          "description": "Extra arguments passed to the Agda process."
        }
      }
    },
    "languages": [
      {
        "id": "agda",
        "extensions": [
          ".agda"
        ],
        "aliases": ["Agda", "agda"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "agda",
        "scopeName": "source.agda",
        "path": "./syntaxes/agda.tmLanguage.json"
      }
    ],
    "keybindings": [
      {
        "command": "agda-mode.load-file",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+l"
      },
      {
        "command": "agda-mode.goal-context",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+e",
        "args": { "rewrite": "AsIs" }
      },
      {
        "command": "agda-mode.goal-context",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+c ctrl+e",
        "args": { "rewrite": "HeadNormal" }
      },
      {
        "command": "agda-mode.goal-context",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+u ctrl+c ctrl+e",
        "args": { "rewrite": "Normalised" }
      },
      {
        "command": "agda-mode.goal-type",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+t",
        "args": { "rewrite": "AsIs" }
      },
      {
        "command": "agda-mode.goal-type",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+c ctrl+t",
        "args": { "rewrite": "HeadNormal" }
      },
      {
        "command": "agda-mode.goal-type",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+u ctrl+c ctrl+t",
        "args": { "rewrite": "Normalised" }
      },
      {
        "command": "agda-mode.goal-env",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+,",
        "args": { "rewrite": "AsIs" }
      },
      {
        "command": "agda-mode.goal-env",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+c ctrl+,",
        "args": { "rewrite": "HeadNormal" }
      },
      {
        "command": "agda-mode.goal-env",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+u ctrl+c ctrl+,",
        "args": { "rewrite": "Normalised" }
      },
      {
        "command": "agda-mode.goal-context-infer",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+.",
        "args": { "rewrite": "AsIs" }
      },
      {
        "command": "agda-mode.goal-context-infer",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+c ctrl+.",
        "args": { "rewrite": "HeadNormal" }
      },
      {
        "command": "agda-mode.goal-context-infer",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+u ctrl+c ctrl+.",
        "args": { "rewrite": "Normalised" }
      },
      {
        "command": "agda-mode.goal-context-elab",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+;",
        "args": { "rewrite": "AsIs" }
      },
      {
        "command": "agda-mode.goal-context-elab",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+c ctrl+;",
        "args": { "rewrite": "HeadNormal" }
      },
      {
        "command": "agda-mode.goal-context-elab",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+u ctrl+c ctrl+;",
        "args": { "rewrite": "Normalised" }
      },
      {
        "command": "agda-mode.next-goal",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+f"
      },
      {
        "command": "agda-mode.prev-goal",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+b"
      },
      {
        "command": "agda-mode.show-metas",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+shift+/",
        "args": { "rewrite": "AsIs" }
      },
      {
        "command": "agda-mode.show-metas",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+c ctrl+shift+/",
        "args": { "rewrite": "HeadNormal" }
      },
      {
        "command": "agda-mode.show-metas",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+u ctrl+c ctrl+shift+/",
        "args": { "rewrite": "Normalised" }
      },
      {
        "command": "agda-mode.show-constraints",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+=",
        "args": { "rewrite": "AsIs" }
      },
      {
        "command": "agda-mode.show-constraints",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+c ctrl+=",
        "args": { "rewrite": "HeadNormal" }
      },
      {
        "command": "agda-mode.show-constraints",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+u ctrl+c ctrl+=",
        "args": { "rewrite": "Normalised" }
      },
      {
        "command": "agda-mode.refine",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+u ctrl+c ctrl+r",
        "args": {
          "pmLambda": true
        }
      },
      {
        "command": "agda-mode.refine",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+r",
        "args": {
          "pmLambda": false
        }
      },
      {
        "command": "agda-mode.give-goal",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+spc",
        "args": {
          "pmLambda": false
        }
      },
      {
        "command": "agda-mode.give-goal",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+u ctrl+c ctrl+spc",
        "args": {
          "pmLambda": true
        }
      },
      {
        "command": "agda-mode.backspace",
        "when": "agda-mode.inInputMode",
        "key": "backspace"
      },
      {
        "command": "agda-mode.arrow-left",
        "when": "agda-mode.inInputMode",
        "key": "left"
      },
      {
        "command": "agda-mode.arrow-right",
        "when": "agda-mode.inInputMode",
        "key": "right"
      },
      {
        "command": "agda-mode.auto-goal",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+a",
        "args": { "rewrite": "AsIs" }
      },
      {
        "command": "agda-mode.auto-goal",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+c ctrl+a",
        "args": { "rewrite": "HeadNormal" }
      },
      {
        "command": "agda-mode.auto-goal",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+u ctrl+c ctrl+a",
        "args": { "rewrite": "Normalised" }
      },
      {
        "command": "agda-mode.compile-file",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+x ctrl+c"
      },
      {
        "command": "agda-mode.make-case",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+c"
      },
      {
        "command": "agda-mode.restart",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+x ctrl+r"
      },
      {
        "command": "agda-mode.infer",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+d",
        "args": { "rewrite": "AsIs" }
      },
      {
        "command": "agda-mode.infer",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+c ctrl+d",
        "args": { "rewrite": "HeadNormal" }
      },
      {
        "command": "agda-mode.infer",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+u ctrl+c ctrl+d",
        "args": { "rewrite": "Normalised" }
      },
      {
        "command": "agda-mode.compute",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+n",
        "args": { "computeMode": "DefaultCompute" }
      },
      {
        "command": "agda-mode.compute",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+c ctrl+n",
        "args": { "computeMode": "IgnoreAbstract" }
      },
      {
        "command": "agda-mode.compute",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+u ctrl+c ctrl+n",
        "args": { "computeMode": "UseShowInstance" }
      },
      {
        "command": "agda-mode.compute",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+u ctrl+u ctrl+c ctrl+n",
        "args": { "computeMode": "HeadCompute" }
      },
      {
        "command": "agda-mode.module-contents",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+o",
        "args": { "rewrite": "AsIs" }
      },
      {
        "command": "agda-mode.module-contents",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+c ctrl+o",
        "args": { "rewrite": "HeadNormal" }
      },
      {
        "command": "agda-mode.module-contents",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+u ctrl+c ctrl+o",
        "args": { "rewrite": "Normalised" }
      },
      {
        "command": "agda-mode.why-in-scope",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+w"
      },
      {
        "command": "agda-mode.toggle-hidden",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+x ctrl+h"
      },
      {
        "command": "agda-mode.toggle-irrelevant",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+x ctrl+i"
      },
      {
        "command": "agda-mode.search-about",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+c ctrl+z",
        "args": { "rewrite": "AsIs" }
      },
      {
        "command": "agda-mode.search-about",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+c ctrl+z",
        "args": { "rewrite": "HeadNormal" }
      },
      {
        "command": "agda-mode.search-about",
        "when": "editorLangId =~ /agda/ && !editor.hasSelection",
        "key": "ctrl+u ctrl+u ctrl+c ctrl+z",
        "args": { "rewrite": "Normalised" }
      }
    ],
    "commands": [
      {
        "command": "agda-mode.load-file",
        "title": "Load an agda file"
      },
      {
        "command": "agda-mode.give-goal",
        "title": "Give goal"
      },
      {
        "command": "agda-mode.goal-context",
        "title": "Goal context"
      },
      {
        "command": "agda-mode.refine",
        "title": "Refine goal"
      },
      {
        "command": "agda-mode.next-goal",
        "title": "Next goal"
      },
      {
        "command": "agda-mode.prev-goal",
        "title": "Previous goal"
      },
      {
        "command": "agda-mode.show-constraints",
        "title": "Show constraints"
      },
      {
        "command": "agda-mode.show-metas",
        "title": "Show all goals"
      },
      {
        "command": "agda-mode.make-case",
        "title": "Make case"
      },
      {
        "command": "agda-mode.auto-goal",
        "title": "Fill hole by automatic proof search"
      },
      {
        "command": "agda-mode.compile-file",
        "title": "Compile file"
      },
      {
        "command": "agda-mode.restart",
        "title": "Restart the agda process"
      }
    ]
  },
  "configurationDefaults": {
    "agda": {
      "editor.semanticHighlighting.enabled": true
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build:webview": "cd modules/agda-mode && agda --js --js-es6 --js-verify --compile-dir=../../out --library-file=../../libraries --no-default-libraries src/AgdaMode/Webview.agda",
    "build:extension": "cd modules/agda-mode && agda --js --js-es6 --js-verify --compile-dir=../../out --library-file=../../libraries --no-default-libraries src/AgdaMode/Extension.agda",
    "build": "npm run build:webview && npm run build:extension && cp modules/agda-mode/src/extension.js out && node esbuild.mjs"
  },
  "dependencies": {
    "p-queue": "^9.1.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.28.0"
  }
}
