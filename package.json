{
  "name": "agda-mode",
  "displayName": "agda-mode",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:agda"
  ],
  "repository": "github:stickyPiston/agda-mode-vscode",
  "main": "./bundle.js",
  "contributes": {
    "configuration": {
      "title": "",
      "type": "object",
      "properties": {
        "agda-mode.agda-path": {
          "type": "string",
          "description": "Path to the agda binary, when left empty, the agda binary on the PATH is used."
        },
        "agda-mode.extra-args": {
          "type": "string",
          "description": "Extra arguments passed to the Agda process."
        }
      }
    },
    "languages": [
      {
        "id": "agda",
        "extensions": [
          ".agda"
        ]
      }
    ],
    "keybindings": [
      {
        "command": "agda-mode.load-file",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+c ctrl+l"
      },
      {
        "command": "agda-mode.goal-context",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+c ctrl+,"
      },
      {
        "command": "agda-mode.goal-type",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+c ctrl+t"
      },
      {
        "command": "agda-mode.goal-env",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+c ctrl+e"
      },
      {
        "command": "agda-mode.goal-context-infer",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+c ctrl+."
      },
      {
        "command": "agda-mode.goal-context-elab",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+c ctrl+;"
      },
      {
        "command": "agda-mode.next-goal",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+c ctrl+f"
      },
      {
        "command": "agda-mode.prev-goal",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+c ctrl+b"
      },
      {
        "command": "agda-mode.show-metas",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+c ctrl+shift+/"
      },
      {
        "command": "agda-mode.show-constraints",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+c ctrl+="
      },
      {
        "command": "agda-mode.refine",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+u ctrl+c ctrl+r",
        "args": {
          "pmLambda": true
        }
      },
      {
        "command": "agda-mode.refine",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+c ctrl+r",
        "args": {
          "pmLambda": false
        }
      },
      {
        "command": "agda-mode.give-goal",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+c ctrl+spc",
        "args": {
          "pmLambda": false
        }
      },
      {
        "command": "agda-mode.give-goal",
        "when": "editorLangId =~ /agda/",
        "key": "ctrl+u ctrl+c ctrl+spc",
        "args": {
          "pmLambda": true
        }
      },
      {
        "command": "agda-mode.backspace",
        "when": "agda-mode.inInputMode",
        "key": "backspace"
      },
      {
        "command": "agda-mode.arrow-left",
        "when": "agda-mode.inInputMode",
        "key": "left"
      },
      {
        "command": "agda-mode.arrow-right",
        "when": "agda-mode.inInputMode",
        "key": "right"
      },
      {
        "command": "agda-mode.auto-goal",
        "key": "ctrl+c ctrl+a"
      },
      {
        "command": "agda-mode.compile-file",
        "key": "ctrl+c ctrl+x ctrl+c"
      },
      {
        "command": "agda-mode.make-case",
        "key": "ctrl+c ctrl+c"
      }
    ],
    "commands": [
      {
        "command": "agda-mode.load-file",
        "title": "Load an agda file"
      },
      {
        "command": "agda-mode.give-goal",
        "title": "Give goal"
      },
      {
        "command": "agda-mode.goal-context",
        "title": "Goal context"
      },
      {
        "command": "agda-mode.refine",
        "title": "Refine goal"
      },
      {
        "command": "agda-mode.next-goal",
        "title": "Next goal"
      },
      {
        "command": "agda-mode.prev-goal",
        "title": "Previous goal"
      },
      {
        "command": "agda-mode.show-constraints",
        "title": "Show constraints"
      },
      {
        "command": "agda-mode.show-metas",
        "title": "Show all goals"
      },
      {
        "command": "agda-mode.make-case",
        "title": "Make case"
      },
      {
        "command": "agda-mode.auto-goal",
        "title": "Fill hole by automatic proof search"
      },
      {
        "command": "agda-mode.compile-file",
        "title": "Compile file"
      }
    ]
  },
  "configurationDefaults": {
    "agda": {
      "editor.semanticHighlighting.enabled": true
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build:webview": "cd modules/agda-mode && agda --js --js-es6 --js-verify --compile-dir=../../out --library-file=../../libraries --no-default-libraries src/AgdaMode/Webview.agda",
    "build:extension": "cd modules/agda-mode && agda --js --js-es6 --js-verify --compile-dir=../../out --library-file=../../libraries --no-default-libraries src/AgdaMode/Extension.agda",
    "build": "npm run build:webview && npm run build:extension && cp modules/agda-mode/src/extension.js out"
  },
  "dependencies": {
    "p-queue": "^9.1.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.28.0"
  }
}
